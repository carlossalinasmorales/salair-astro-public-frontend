---
import '@styles/global.css';
import '@styles/patterns.css';
import appleTouchIcon from '@assets/identity/apple-touch-icon.png';
import socialImage from '@assets/identity/android-chrome-512x512.png';
import favicon16 from '@assets/identity/favicon-16x16.png';
import favicon32 from '@assets/identity/favicon-32x32.png';
import faviconIco from '@assets/identity/favicon.ico';
import montserrat400 from '@assets/fonts/montserrat/montserrat-latin-400-normal.woff2';
import montserrat600 from '@assets/fonts/montserrat/montserrat-latin-600-normal.woff2';

interface Props {
  title?: string;
  description?: string;
  robots?: string;
}

const {
  title = 'Salair — Climatización y Refrigeración Industrial',
  description = 'Soluciones profesionales de climatización y refrigeración industrial en Chile. Ofrecemos servicios de instalación, mantención, reparación y atención de emergencias principalmente para sistemas industriales como aire acondicionado, camaras frigorificas, ductería, estractores de aire, entre otros.',
  robots = 'index, follow',
} = Astro.props;

const toAssetUrl = (asset: string | { src: string }) =>
  typeof asset === 'string' ? asset : asset.src;

const baseUrl = Astro.site ?? new URL(Astro.url.origin);
const canonicalUrl = new URL(Astro.url.pathname, baseUrl).toString();
const socialImageUrl = new URL(toAssetUrl(socialImage), baseUrl).toString();
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />

    <link rel="apple-touch-icon" sizes="180x180" href={toAssetUrl(appleTouchIcon)} />
    <link rel="icon" type="image/png" sizes="32x32" href={toAssetUrl(favicon32)} />
    <link rel="icon" type="image/png" sizes="16x16" href={toAssetUrl(favicon16)} />
    <link rel="shortcut icon" href={toAssetUrl(faviconIco)} />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#091A38" />
    <link rel="preload" href={montserrat400} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={montserrat600} as="font" type="font/woff2" crossorigin />

    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
