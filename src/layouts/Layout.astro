---
import "@styles/global.css";
import { Font } from "astro:assets";
import appleTouchIcon from "@assets/identity/apple-touch-icon.png";
import socialImage from "@assets/identity/android-chrome-512x512.png";
import favicon16 from "@assets/identity/favicon-16x16.png";
import favicon32 from "@assets/identity/favicon-32x32.png";
import faviconIco from "@assets/identity/favicon.ico";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Salair — Climatización y Refrigeración Profesional en Chile",
  description = "Soluciones profesionales de climatización y refrigeración industrial en Chile: ingeniería, instalación, mantenimiento y continuidad operativa.",
} = Astro.props;

const toAssetUrl = (asset: string | { src: string }) =>
  typeof asset === "string" ? asset : asset.src;

const baseUrl = Astro.site ?? new URL(Astro.url.origin);
const canonicalUrl = new URL(Astro.url.pathname, baseUrl).toString();
const socialImageUrl = new URL(toAssetUrl(socialImage), baseUrl).toString();
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />

    <link rel="apple-touch-icon" sizes="180x180" href={toAssetUrl(appleTouchIcon)} />
    <link rel="icon" type="image/png" sizes="32x32" href={toAssetUrl(favicon32)} />
    <link rel="icon" type="image/png" sizes="16x16" href={toAssetUrl(favicon16)} />
    <link rel="shortcut icon" href={toAssetUrl(faviconIco)} />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#091A38" />
    <Font cssVariable="--font-montserrat" preload/>

    <title>{title}</title>
  </head>
  <body>

    <slot />
  </body>
</html>
