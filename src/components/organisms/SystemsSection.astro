---
import SectionHeading from "@molecules/SectionHeading.astro";
import SystemCard from "@molecules/SystemCard.astro";
import { sectionShellClasses } from "@styles/section-shell";
import { systems } from "@/lib/content/systems";

const systemsTopRow = systems.slice(0, 3);
const systemsBottomRow = systems.slice(3);

const systemsGridBaseClasses = "mx-auto grid bg-neutral-100";

---

<section id="sistemas" class={sectionShellClasses}>
  <div class="container">
    <SectionHeading title="Cubrimos los sistemas críticos que sostienen tu operación." />

    <div class={`${systemsGridBaseClasses} max-w-6xl grid-cols-1 sm:grid-cols-2 lg:hidden`}>
      {systems.map((system) => (
        <SystemCard
          title={system.title}
          description={system.description}
          image={system.image}
          alt={system.alt}
        />
      ))}
    </div>

    <div class="hidden lg:block">
      <div class={`${systemsGridBaseClasses} max-w-6xl grid-cols-3`}>
        {systemsTopRow.map((system) => (
          <SystemCard
            title={system.title}
            description={system.description}
            image={system.image}
            alt={system.alt}
          />
        ))}
      </div>

      <div class={`${systemsGridBaseClasses} max-w-4xl grid-cols-2`}>
        {systemsBottomRow.map((system) => (
          <SystemCard
            title={system.title}
            description={system.description}
            image={system.image}
            alt={system.alt}
          />
        ))}
      </div>
    </div>
  </div>
</section>
