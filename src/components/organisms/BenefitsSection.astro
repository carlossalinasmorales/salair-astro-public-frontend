---
import BenefitItem from "@molecules/BenefitItem.astro";
import SectionHeading from "@molecules/SectionHeading.astro";

const benefits = [
  {
    number: "01",
    title: "Técnicos especializados",
    description: "Equipo técnico con experiencia real en climatización, refrigeración y ventilación para operaciones exigentes.",
  },
  {
    number: "02",
    title: "Comunicación clara y directa",
    description: "Le informamos lo necesario, en términos claros, para que pueda decidir con respaldo técnico.",
  },
  {
    number: "03",
    title: "Presupuestos transparentes",
    description: "Propuestas con alcance, plazos y costos definidos desde el inicio, sin sorpresas en el camino.",
  },
  {
    number: "04",
    title: "Servicios contractuales y esporádicos",
    description: "Nos adaptamos a su operación: contratos recurrentes o atenciones puntuales cuando lo requiera.",
  },
  {
    number: "05",
    title: "Garantía extendida en instalaciones",
    description: "Respaldo técnico adicional para proteger la inversión y asegurar buen desempeño post instalación.",
  },
  {
    number: "06",
    title: "Foco en su continuidad operativa",
    description: "Cada intervención apunta a reducir detenciones y mantener su operación en marcha.",
  },
  {
    number: "07",
    title: "Clientes grandes",
    description: "Trabajamos con empresas de alto estándar operativo en distintos rubros productivos y comerciales.",
  },
  {
    number: "08",
    title: "Cobertura nacional",
    description: "Atención técnica en todo Chile, de norte a sur, con equipos preparados para distintos contextos.",
  },
];
---

<section id="nosotros" class="bg-neutral-100 py-20 lg:py-28">
  <div class="container">
    <SectionHeading
      title="¿Qué ganás trabajando con SALAIR?"
    />

    <div class="mx-auto grid max-w-6xl grid-cols-1 gap-0 lg:grid-cols-2">
      {benefits.map((benefit) => (
        <BenefitItem number={benefit.number} title={benefit.title} description={benefit.description} />
      ))}
    </div>
  </div>
</section>
