---
import { Image } from "astro:assets";
import Icon from "@atoms/Icon.astro";
import Button from "@atoms/Button.astro";
import SurfaceCard from "@atoms/SurfaceCard.astro";
import SectionHeading from "@molecules/SectionHeading.astro";

import aireAcondicionadoIndustrial from "@/assets/images/equipos/aire-acondicionado-industrial.webp";
import camarasDeRefrigeracion from "@/assets/images/equipos/camaras-de-refrigeracion.webp";
import camarasDeCongelado from "@/assets/images/equipos/camaras-de-congelado.webp";
import ductosDeVentilacion from "@/assets/images/equipos/ductos-de-ventilacion.webp";
import extractoresDeAire from "@/assets/images/equipos/extractores-de-aire.webp";

const workAreas = [
  {
    title: "Aires acondicionados",
    iconName: "thermometer",
    description: "Soluciones de climatización para confort térmico y control de temperatura en operaciones comerciales e industriales.",
    image: aireAcondicionadoIndustrial,
    alt: "Equipo de aire acondicionado industrial",
  },
  {
    title: "Cámaras de mantención",
    iconName: "snowflake",
    description: "Sistemas de refrigeración para conservación de productos con control estable de temperatura y operación continua.",
    image: camarasDeRefrigeracion,
    alt: "Cámara de mantención frigorífica",
  },
  {
    title: "Cámaras de congelado",
    iconName: "factory",
    description: "Infraestructura para cadena de frío de baja temperatura, pensada para exigencias sanitarias y logísticas.",
    image: camarasDeCongelado,
    alt: "Cámara de congelado industrial",
  },
  {
    title: "Ductería",
    iconName: "building",
    description: "Diseño e implementación de redes de ductos para ventilación y climatización con enfoque en eficiencia de flujo.",
    image: ductosDeVentilacion,
    alt: "Sistema de ductería de ventilación",
  },
  {
    title: "Extractores de aire",
    iconName: "zap",
    description: "Extracción y renovación de aire para ambientes productivos, cocinas industriales y espacios de alta demanda.",
    image: extractoresDeAire,
    alt: "Extractores de aire instalados en operación",
  },
];
---

<section id="areas-de-trabajo" class=" bg-neutral-100 py-20 lg:py-28">
  <div class="container">
    <SectionHeading
      title="Áreas de trabajo principales"
      description="Operamos en todo Chile, de norte a sur, atendiendo infraestructura crítica en climatización, refrigeración y ventilación."
    />

    <div class="flex flex-wrap justify-center gap-6">
      {workAreas.map((area) => (
        <SurfaceCard
          as="article"
          tone="neutral"
          interactive
          class="group relative h-80 w-full overflow-hidden p-0 md:h-84 md:w-[calc(50%-0.75rem)] xl:h-88 xl:w-[calc(33.333%-1rem)]"
        >
          <div aria-hidden="true" class="absolute inset-x-0 top-0 h-1 bg-linear-to-r from-primary-500 via-secondary-500 to-primary-300 opacity-80"></div>
          <Image
            src={area.image}
            alt={area.alt}
            widths={[480, 720]}
            sizes="(max-width: 768px) 100vw, (max-width: 1280px) 50vw, 33vw"
            class="absolute inset-0 h-full w-full object-cover"
            loading="lazy"
            format="webp"
          />
          <div aria-hidden="true" class="absolute inset-0 bg-linear-to-b from-secondary-900/20 via-secondary-900/35 to-secondary-900/88"></div>

          <div class="absolute inset-x-0 bottom-0 z-10 p-6">
            <div class="mb-3 flex items-center gap-3">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-white/15 text-white shadow-[0_10px_20px_-14px_rgba(2,6,15,0.95)] ring-1 ring-white/35 backdrop-blur-[1px]">
                <Icon name={area.iconName} class="h-4.5 w-4.5" />
              </div>
              <h3 class="text-xl font-bold text-white">{area.title}</h3>
            </div>
            <p class="text-sm leading-relaxed text-secondary-100">{area.description}</p>
          </div>
        </SurfaceCard>
      ))}
    </div>

    <div class="mt-10 flex justify-center">
      <Button href="#contacto" variant="accent" size="lg">Solicitar asesoría para mi operación</Button>
    </div>
  </div>
</section>
