---
import Button from "@atoms/Button.astro";
import ContactItem from "@molecules/ContactItem.astro";
---

<section id="contacto" class="border-t border-secondary-200 bg-neutral-100 py-20 lg:py-28">
  <div class="container">
    <div class="grid items-start gap-10 lg:grid-cols-2 lg:gap-16">
      <div>
        <h2 class="mt-4 text-3xl font-black text-secondary-500 sm:text-4xl lg:text-5xl">
          Solicite una evaluación técnica
        </h2>
        <p class="mt-6 text-lg text-secondary-300">
          Revisamos su contexto operativo y definimos una propuesta de solución con alcance,
          cronograma y requerimientos técnicos.
        </p>

        <div class="mt-8 space-y-4">
          <ContactItem iconName="phone" label="Teléfono" value="+56 9 1234 5678" href="tel:+56912345678" />
          <ContactItem iconName="mail" label="Correo electrónico" value="contacto@salair.cl" href="mailto:contacto@salair.cl" />
          <ContactItem iconName="location" label="Oficina central" value="Santiago de Chile" />
          <ContactItem iconName="clock" label="Horario" value="Lunes a viernes de 08:00 a 18:00 · Emergencias 24/7" />
        </div>

        <article class="mt-8 rounded-2xl border border-secondary-200/80 bg-white p-6 shadow-[0_14px_28px_-22px_rgba(9,26,56,0.65)]">
          <h3 class="text-base font-bold text-secondary-500">Información corporativa</h3>
          <ul class="mt-3 space-y-2 text-sm text-secondary-300">
            <li>RUT: 76.XXX.XXX-X</li>
            <li>Certificaciones SEC disponibles bajo solicitud</li>
            <li>Cotización técnica sin compromiso comercial</li>
          </ul>
        </article>
      </div>

      <div class="rounded-2xl border border-secondary-200/80 bg-white p-8 shadow-[0_14px_28px_-22px_rgba(9,26,56,0.65)] lg:p-10">
        <h3 class="text-2xl font-bold text-secondary-500">Formulario de contacto B2B</h3>
        <p class="mt-2 text-sm text-secondary-300">Le responderemos dentro de 24 horas hábiles.</p>

        <form id="contact-form" class="mt-8 space-y-5" novalidate>
          <div>
            <label for="company" class="mb-2 block text-sm font-semibold text-secondary-500">Empresa *</label>
            <input
              type="text"
              id="company"
              name="company"
                autocomplete="organization"
                required
                placeholder="Ej: Planta Andina SpA"
                class="w-full rounded-xl border border-secondary-200 bg-neutral-100 px-4 py-3 text-sm text-secondary-500 placeholder-secondary-300 transition-colors hover:border-secondary-300 focus-visible:border-primary-400"
              />
            </div>

          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div>
              <label for="name" class="mb-2 block text-sm font-semibold text-secondary-500">Nombre completo *</label>
              <input
                type="text"
                id="name"
                name="name"
                autocomplete="name"
                required
                placeholder="Nombre y apellido"
                class="w-full rounded-xl border border-secondary-200 bg-neutral-100 px-4 py-3 text-sm text-secondary-500 placeholder-secondary-300 transition-colors hover:border-secondary-300 focus-visible:border-primary-400"
              />
            </div>
            <div>
              <label for="role" class="mb-2 block text-sm font-semibold text-secondary-500">Cargo *</label>
              <input
                type="text"
                id="role"
                name="role"
                required
                placeholder="Ej: Jefatura de Operaciones"
                class="w-full rounded-xl border border-secondary-200 bg-neutral-100 px-4 py-3 text-sm text-secondary-500 placeholder-secondary-300 transition-colors hover:border-secondary-300 focus-visible:border-primary-400"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div>
              <label for="email" class="mb-2 block text-sm font-semibold text-secondary-500">Correo corporativo *</label>
              <input
                type="email"
                id="email"
                name="email"
                autocomplete="email"
                required
                placeholder="su@empresa.cl"
                class="w-full rounded-xl border border-secondary-200 bg-neutral-100 px-4 py-3 text-sm text-secondary-500 placeholder-secondary-300 transition-colors hover:border-secondary-300 focus-visible:border-primary-400"
              />
            </div>
            <div>
              <label for="phone" class="mb-2 block text-sm font-semibold text-secondary-500">Teléfono *</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                autocomplete="tel"
                required
                placeholder="+56 9 1234 5678"
                class="w-full rounded-xl border border-secondary-200 bg-neutral-100 px-4 py-3 text-sm text-secondary-500 placeholder-secondary-300 transition-colors hover:border-secondary-300 focus-visible:border-primary-400"
              />
            </div>
          </div>

          <div>
            <label for="service" class="mb-2 block text-sm font-semibold text-secondary-500">Tipo de proyecto</label>
              <select
                id="service"
                name="service"
                class="w-full cursor-pointer appearance-none rounded-xl border border-secondary-200 bg-neutral-100 px-4 py-3 text-sm text-secondary-500 placeholder-secondary-300 transition-colors hover:border-secondary-300 focus-visible:border-primary-400"
              >
                <option value="">Seleccionar</option>
              <option value="hvac-industrial">HVAC Industrial</option>
              <option value="refrigeracion">Refrigeración Comercial</option>
              <option value="instalacion">Proyecto llave en mano</option>
              <option value="mantenimiento">Mantenimiento contractual</option>
              <option value="auditoria">Auditoría técnica</option>
              <option value="emergencia">Atención de emergencias</option>
            </select>
          </div>

          <div>
            <label for="message" class="mb-2 block text-sm font-semibold text-secondary-500">Descripción del requerimiento</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              placeholder="Contexto operativo, metraje estimado, criticidad y plazo objetivo"
              class="w-full resize-none rounded-xl border border-secondary-200 bg-neutral-100 px-4 py-3 text-sm text-secondary-500 placeholder-secondary-300 transition-colors hover:border-secondary-300 focus-visible:border-primary-400"
            ></textarea>
          </div>

          <Button type="submit" size="lg" class="w-full">
            <span id="btn-text">Enviar solicitud técnica</span>
          </Button>

          <div id="success-msg" class="hidden rounded-md border border-primary-300 bg-primary-100 p-4 text-center text-sm text-primary-700">
            Solicitud enviada correctamente. Nuestro equipo se contactará a la brevedad.
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const submitBtn = document.getElementById("contact-form")?.querySelector("button[type=submit]") as HTMLButtonElement | null;
  const btnText = document.getElementById("btn-text");
  const successMsg = document.getElementById("success-msg");

  if (form && submitBtn && btnText && successMsg) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const name = (form.querySelector("#name") as HTMLInputElement).value.trim();
      const email = (form.querySelector("#email") as HTMLInputElement).value.trim();
      const phone = (form.querySelector("#phone") as HTMLInputElement).value.trim();
      const company = (form.querySelector("#company") as HTMLInputElement).value.trim();

      if (!name || !email || !phone || !company) {
        alert("Por favor complete todos los campos obligatorios.");
        return;
      }

      submitBtn.disabled = true;
      btnText.textContent = "Enviando solicitud...";

      await new Promise((resolve) => setTimeout(resolve, 1200));

      submitBtn.disabled = false;
      btnText.textContent = "Solicitud enviada";
      successMsg.classList.remove("hidden");
      form.reset();

      setTimeout(() => {
        btnText.textContent = "Enviar solicitud técnica";
        successMsg.classList.add("hidden");
      }, 3500);
    });
  }
</script>
