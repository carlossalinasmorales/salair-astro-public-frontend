---
import Button from "@atoms/Button.astro";
import SectionHeading from "@molecules/SectionHeading.astro";
import FormField from "@molecules/FormField.astro";
import FormTextareaField from "@molecules/FormTextareaField.astro";
---

<section id="contacto" class=" bg-primary-500 py-20 lg:py-28">
  <div class="container">
    <SectionHeading title="Contacto" tone="dark" align="center"  />
    <div class="grid items-start gap-10 lg:grid-cols-2 lg:gap-16">
      
      <div>
        <p class="mt-6 text-lg text-primary-100">
          Contanos el contexto operativo y te respondemos con una evaluación inicial en hasta 24 horas hábiles.
        </p>

        <ul class="mt-6 space-y-3 text-sm text-primary-100/95 sm:text-base">
          <li>• Tipo de operación y criticidad del requerimiento.</li>
          <li>• Ubicación y ventana estimada para la intervención.</li>
          <li>• Alcance esperado: instalación, reparación, mantención o proyecto.</li>
        </ul>

        <div class="mt-8 rounded-2xl border border-primary-300/50 bg-primary-600/25 p-5">
          <p class="text-sm font-semibold text-white">Contacto directo para urgencias</p>
          <a href="mailto:contacto@salair.cl" class="mt-1 inline-block text-base font-semibold text-primary-100 underline decoration-primary-200/70 underline-offset-4 hover:text-white hover:decoration-white">
            contacto@salair.cl
          </a>
          <p class="mt-3 text-sm text-primary-100/90">Cobertura operativa: todo Chile</p>
        </div>
      </div>

      <div class="rounded-2xl border border-primary-200/60 bg-white p-8 shadow-[0_24px_44px_-30px_rgba(0,0,0,0.45)]">


        <form id="contact-form" class="space-y-5" novalidate>
          <FormField
            id="company"
            name="company"
            label="Empresa"
            autocomplete="organization"
            required
            placeholder="Ej: Planta Andina SpA"
          />

          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <FormField
              id="firstName"
              name="firstName"
              label="Nombre"
              autocomplete="given-name"
              required
              placeholder="Nombre"
            />
            <FormField
              id="lastName"
              name="lastName"
              label="Apellido"
              autocomplete="family-name"
              required
              placeholder="Apellido"
            />
          </div>

          <FormField id="role" name="role" label="Cargo" placeholder="Ej: Jefatura de Operaciones" />

          <FormField
            id="email"
            name="email"
            type="email"
            label="Correo corporativo"
            autocomplete="email"
            required
            placeholder="su@empresa.cl"
          />

          <FormTextareaField
            id="message"
            name="message"
            label="Mensaje"
            rows={4}
            required
            placeholder="Contexto operativo, metraje estimado, criticidad y plazo objetivo"
          />

          <Button type="submit" variant="accent" class="w-full">
            <span id="btn-text">Enviar</span>
          </Button>

          <p class="text-xs text-secondary-300">
            Al enviar este formulario acepta que usemos estos datos para contactarlo y preparar una propuesta.
          </p>

          <div id="success-msg" class="hidden rounded-md border border-primary-300 bg-primary-100 p-4 text-center text-sm text-primary-700">
            Solicitud enviada correctamente. Nuestro equipo se contactará a la brevedad.
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const form = document.getElementById("contact-form");
  const submitBtn = document
    .getElementById("contact-form")
    ?.querySelector("button[type=submit]");
  const btnText = document.getElementById("btn-text");
  const successMsg = document.getElementById("success-msg");

  if (
    form instanceof HTMLFormElement &&
    submitBtn instanceof HTMLButtonElement &&
    btnText instanceof HTMLElement &&
    successMsg instanceof HTMLElement
  ) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const firstNameInput = form.querySelector("#firstName");
      const lastNameInput = form.querySelector("#lastName");
      const emailInput = form.querySelector("#email");
      const messageInput = form.querySelector("#message");
      const companyInput = form.querySelector("#company");

      if (
        !(firstNameInput instanceof HTMLInputElement) ||
        !(lastNameInput instanceof HTMLInputElement) ||
        !(emailInput instanceof HTMLInputElement) ||
        !(messageInput instanceof HTMLTextAreaElement) ||
        !(companyInput instanceof HTMLInputElement)
      ) {
        return;
      }

      const firstName = firstNameInput.value.trim();
      const lastName = lastNameInput.value.trim();
      const email = emailInput.value.trim();
      const message = messageInput.value.trim();
      const company = companyInput.value.trim();

      if (!firstName || !lastName || !email || !message || !company) {
        alert("Por favor complete todos los campos obligatorios.");
        return;
      }

      submitBtn.disabled = true;
      btnText.textContent = "Enviando solicitud...";

      await new Promise((resolve) => setTimeout(resolve, 1200));

      submitBtn.disabled = false;
      btnText.textContent = "Solicitud enviada";
      successMsg.classList.remove("hidden");
      form.reset();

      setTimeout(() => {
        btnText.textContent = "Enviar solicitud técnica";
        successMsg.classList.add("hidden");
      }, 3500);
    });
  }
</script>
