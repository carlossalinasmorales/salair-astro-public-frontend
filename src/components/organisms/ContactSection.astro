---
import Button from "@atoms/Button.astro";
---

<section id="contacto" class=" bg-primary-500 py-20 lg:py-28">
  <div class="container">
    <div class="grid items-start gap-10 lg:grid-cols-2 lg:gap-16">
      <div>
        <h2 class="mt-4 text-3xl font-black text-white sm:text-4xl lg:text-5xl">
          Conversemos tu requerimiento
        </h2>
        <p class="mt-6 text-lg text-primary-100">
          Contanos brevemente tu contexto y te responderemos con una evaluación inicial en hasta 24 horas hábiles.
        </p>

        <p class="mt-4 text-base text-primary-100/95">
          Trabajamos con operaciones industriales y comerciales que no pueden detenerse. Nuestro enfoque combina
          diagnóstico técnico, propuesta clara y plan de ejecución realista según criticidad, plazo y presupuesto.
        </p>

        <div class="mt-8 space-y-4">
          <article class="rounded-2xl border border-primary-200/60 bg-primary-400/30 p-5 backdrop-blur-[1px]">
            <h3 class="text-base font-bold text-white">¿Qué vas a recibir en esta primera respuesta?</h3>
            <ul class="mt-3 space-y-2 text-sm text-primary-100/95">
              <li>• Diagnóstico inicial del requerimiento y nivel de urgencia.</li>
              <li>• Recomendación de servicio (instalación, reparación, mantención o proyecto).</li>
              <li>• Próximos pasos con alcance técnico y tiempos estimados.</li>
            </ul>
          </article>

          <article class="rounded-2xl border border-primary-200/60 bg-primary-400/30 p-5 backdrop-blur-[1px]">
            <h3 class="text-base font-bold text-white">Cobertura operativa nacional</h3>
            <p class="mt-2 text-sm text-primary-100/95">
              Atendemos operaciones en todo Chile, de norte a sur, en climatización, refrigeración y ventilación
              para infraestructura crítica.
            </p>
          </article>
        </div>

        <p class="mt-4 text-sm text-primary-100/90">
          Si se trata de una urgencia operativa, podés escribir a
          <a href="mailto:contacto@salair.cl" class="font-semibold text-white underline decoration-primary-200/70 underline-offset-4 hover:decoration-white">
            contacto@salair.cl
          </a>.
        </p>
      </div>

      <div class="rounded-2xl border border-primary-200/60 bg-white p-8 shadow-[0_24px_44px_-30px_rgba(0,0,0,0.45)] lg:p-10">
        <h3 class="text-2xl font-bold text-secondary-500">Formulario de contacto</h3>
        <p class="mt-2 text-sm text-secondary-300">
          Completá estos datos y te contactamos a la brevedad.
        </p>

        <form id="contact-form" class="mt-8 space-y-5" novalidate>
          <div>
            <label for="company" class="mb-2 block text-sm font-semibold text-secondary-500">Empresa *</label>
            <input
              type="text"
              id="company"
              name="company"
              autocomplete="organization"
              required
              placeholder="Ej: Planta Andina SpA"
              class="w-full rounded-xl border border-secondary-200 bg-neutral-100 px-4 py-3 text-sm text-secondary-500 placeholder-secondary-300 transition-colors hover:border-secondary-300 focus-visible:border-primary-400"
            />
          </div>

          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div>
              <label for="firstName" class="mb-2 block text-sm font-semibold text-secondary-500">Nombre *</label>
              <input
                type="text"
                id="firstName"
                name="firstName"
                autocomplete="given-name"
                required
                placeholder="Nombre"
                class="w-full rounded-xl border border-secondary-200 bg-neutral-100 px-4 py-3 text-sm text-secondary-500 placeholder-secondary-300 transition-colors hover:border-secondary-300 focus-visible:border-primary-400"
              />
            </div>
            <div>
              <label for="lastName" class="mb-2 block text-sm font-semibold text-secondary-500">Apellido *</label>
              <input
                type="text"
                id="lastName"
                name="lastName"
                autocomplete="family-name"
                required
                placeholder="Apellido"
                class="w-full rounded-xl border border-secondary-200 bg-neutral-100 px-4 py-3 text-sm text-secondary-500 placeholder-secondary-300 transition-colors hover:border-secondary-300 focus-visible:border-primary-400"
              />
            </div>
          </div>

          <div>
            <label for="role" class="mb-2 block text-sm font-semibold text-secondary-500">Cargo</label>
            <input
              type="text"
              id="role"
              name="role"
              placeholder="Ej: Jefatura de Operaciones"
              class="w-full rounded-xl border border-secondary-200 bg-neutral-100 px-4 py-3 text-sm text-secondary-500 placeholder-secondary-300 transition-colors hover:border-secondary-300 focus-visible:border-primary-400"
            />
          </div>

          <div>
            <label for="email" class="mb-2 block text-sm font-semibold text-secondary-500">Correo corporativo *</label>
            <input
              type="email"
              id="email"
              name="email"
              autocomplete="email"
              required
              placeholder="su@empresa.cl"
              class="w-full rounded-xl border border-secondary-200 bg-neutral-100 px-4 py-3 text-sm text-secondary-500 placeholder-secondary-300 transition-colors hover:border-secondary-300 focus-visible:border-primary-400"
            />
          </div>

          <div>
            <label for="message" class="mb-2 block text-sm font-semibold text-secondary-500">Mensaje *</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              required
              placeholder="Contexto operativo, metraje estimado, criticidad y plazo objetivo"
              class="w-full resize-none rounded-xl border border-secondary-200 bg-neutral-100 px-4 py-3 text-sm text-secondary-500 placeholder-secondary-300 transition-colors hover:border-secondary-300 focus-visible:border-primary-400"
            ></textarea>
          </div>

          <Button type="submit" variant="accent" size="lg" class="w-full">
            <span id="btn-text">Enviar</span>
          </Button>

          <p class="text-xs text-secondary-300">
            Al enviar este formulario aceptás que usemos estos datos para contactarte y preparar una propuesta.
          </p>

          <div id="success-msg" class="hidden rounded-md border border-primary-300 bg-primary-100 p-4 text-center text-sm text-primary-700">
            Solicitud enviada correctamente. Nuestro equipo se contactará a la brevedad.
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const form = document.getElementById("contact-form");
  const submitBtn = document
    .getElementById("contact-form")
    ?.querySelector("button[type=submit]");
  const btnText = document.getElementById("btn-text");
  const successMsg = document.getElementById("success-msg");

  if (
    form instanceof HTMLFormElement &&
    submitBtn instanceof HTMLButtonElement &&
    btnText instanceof HTMLElement &&
    successMsg instanceof HTMLElement
  ) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const firstNameInput = form.querySelector("#firstName");
      const lastNameInput = form.querySelector("#lastName");
      const emailInput = form.querySelector("#email");
      const messageInput = form.querySelector("#message");
      const companyInput = form.querySelector("#company");

      if (
        !(firstNameInput instanceof HTMLInputElement) ||
        !(lastNameInput instanceof HTMLInputElement) ||
        !(emailInput instanceof HTMLInputElement) ||
        !(messageInput instanceof HTMLTextAreaElement) ||
        !(companyInput instanceof HTMLInputElement)
      ) {
        return;
      }

      const firstName = firstNameInput.value.trim();
      const lastName = lastNameInput.value.trim();
      const email = emailInput.value.trim();
      const message = messageInput.value.trim();
      const company = companyInput.value.trim();

      if (!firstName || !lastName || !email || !message || !company) {
        alert("Por favor complete todos los campos obligatorios.");
        return;
      }

      submitBtn.disabled = true;
      btnText.textContent = "Enviando solicitud...";

      await new Promise((resolve) => setTimeout(resolve, 1200));

      submitBtn.disabled = false;
      btnText.textContent = "Solicitud enviada";
      successMsg.classList.remove("hidden");
      form.reset();

      setTimeout(() => {
        btnText.textContent = "Enviar solicitud técnica";
        successMsg.classList.add("hidden");
      }, 3500);
    });
  }
</script>
