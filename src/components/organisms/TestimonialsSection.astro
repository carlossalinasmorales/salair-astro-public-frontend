---
import TestimonialsCarouselIsland from "./TestimonialsCarouselIsland";
import SectionHeading from "@molecules/SectionHeading.astro";

const testimonials = [
  {
    quote: "Implementaron un sistema centralizado de climatización para nuestra planta de 5.000 m². El proyecto se entregó en plazo y el consumo energético se redujo un 23% durante el primer año.",
    name: "Roberto Méndez",
    role: "Director de Operaciones",
    company: "Industrial Foods Chile",
    location: "Quilicura, Santiago",
    avatar: "RM",
  },
  {
    quote: "Contratamos un plan anual de mantenimiento para 12 locales. La reducción de incidencias fue del 85% y hoy contamos con reportes técnicos que facilitan la toma de decisiones.",
    name: "Patricia Vega",
    role: "Gerente de Facilities",
    company: "Grupo Comercial Sur",
    location: "Región Metropolitana",
    avatar: "PV",
  },
  {
    quote: "Tuvimos una contingencia crítica en cámara de frío durante un fin de semana. El equipo llegó en menos de seis horas y evitamos pérdidas de mercadería.",
    name: "Carlos Ruiz",
    role: "Supply Chain Manager",
    company: "Logística Andes SpA",
    location: "Pudahuel, Santiago",
    avatar: "CR",
  },
];
---

<section id="testimonios" class="border-t border-secondary-200/80 bg-neutral-100 py-20 lg:py-28">
  <div class="container">
    <SectionHeading
      title="Experiencias de clientes industriales y comerciales"
      description="Empresas de distintos sectores validan nuestra capacidad para sostener operaciones críticas."
    />


    <TestimonialsCarouselIsland testimonials={testimonials} client:idle />
  </div>
</section>
