---
import TestimonialsCarouselIsland from "./TestimonialsCarouselIsland";
import SectionHeading from "@molecules/SectionHeading.astro";
import { sectionShellClasses } from "@styles/section-shell";
import { testimonials } from "@/lib/content/testimonials";
---

<section id="testimonios" class={sectionShellClasses}>
  <div class="container">
    <SectionHeading
      title="Empresas como la tuya ya operan con más tranquilidad."
    />
    <TestimonialsCarouselIsland testimonials={testimonials} client:idle />
  </div>
</section>
