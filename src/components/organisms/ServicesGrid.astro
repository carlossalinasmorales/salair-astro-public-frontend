---
import ServiceCard from "@molecules/ServiceCard.astro";
import SectionHeading from "@molecules/SectionHeading.astro";

const services = [
  {
    iconName: "building",
    title: "Instalaciones",
    description: "Implementamos sistemas de climatización y refrigeración con puesta en marcha en terreno y verificación de funcionamiento.",
  },
  {
    iconName: "wrench",
    title: "Reparaciones",
    description: "Diagnosticamos y resolvemos fallas en equipos de climatización y refrigeración industrial para reducir detenciones y recuperar operación segura.",
  },
  {
    iconName: "calendar",
    title: "Mantenciones",
    description: "Ejecutamos mantenciones preventivas y correctivas para extender la vida útil de los equipos y evitar fallas repetitivas.",
  },
  {
    iconName: "zap",
    title: "Emergencias",
    description: "Respondemos contingencias críticas con atención prioritaria y reporte claro de lo ejecutado en cada intervención.",
  },
  {
    iconName: "document",
    title: "Proyectos",
    description: "Desarrollamos proyectos de climatización y refrigeración industrial desde la definición técnica hasta la implementación y entrega operativa.",
  },
];

const servicesTopRow = services.slice(0, 3);
const servicesBottomRow = services.slice(3);
---

<section id="servicios" class="bg-neutral-100 py-20 lg:py-28" data-services-grid>
  <div class="container">
    <SectionHeading
      title="Nuestros servicios sostienen tu continuidad operativa."
    />


    <div class="services-grid-reference mx-auto grid max-w-6xl grid-cols-1    bg-neutral-100 sm:grid-cols-2 lg:hidden">
      {services.map((service) => (
        <ServiceCard
          title={service.title}
          description={service.description}
          iconName={service.iconName}
          class="service-card-equalized   "
        />
      ))}
    </div>

    <div class="hidden lg:block">
      <div class="services-grid-reference mx-auto grid max-w-6xl grid-cols-3    bg-neutral-100">
        {servicesTopRow.map((service) => (
          <ServiceCard
            title={service.title}
            description={service.description}
            iconName={service.iconName}
            class="service-card-equalized   "
          />
        ))}
      </div>

      <div class="services-grid-reference mx-auto grid max-w-4xl grid-cols-2    bg-neutral-100">
        {servicesBottomRow.map((service) => (
          <ServiceCard
            title={service.title}
            description={service.description}
            iconName={service.iconName}
            class="service-card-equalized   "
          />
        ))}
      </div>
    </div>


  </div>
</section>

<script>
  const setupServicesCardHeight = () => {
    const section = document.querySelector('[data-services-grid]');
    if (!section) return;

    const cards = Array.from(section.querySelectorAll<HTMLElement>('.service-card-equalized'));
    if (cards.length === 0) return;

    cards.forEach((card) => {
      card.style.minHeight = '';
    });

    const tallest = Math.max(...cards.map((card) => card.offsetHeight));

    cards.forEach((card) => {
      card.style.minHeight = `${tallest}px`;
    });
  };

  let resizeTimer: ReturnType<typeof window.setTimeout> | undefined;

  const onResize = () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(setupServicesCardHeight, 120);
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupServicesCardHeight, { once: true });
  } else {
    setupServicesCardHeight();
  }

  window.addEventListener('resize', onResize);
</script>

<style>
  .services-grid-reference :global(.service-card-reference) {
    min-height: 17.5rem;
  }

  @media (min-width: 1024px) {
    .services-grid-reference :global(.service-card-reference) {
      min-height: 18.5rem;
    }
  }
</style>
