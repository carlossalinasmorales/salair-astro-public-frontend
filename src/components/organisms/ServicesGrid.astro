---
import ServiceCard from "@molecules/ServiceCard.astro";
import SectionHeading from "@molecules/SectionHeading.astro";
import Button from "@atoms/Button.astro";

const services = [
  {
    iconName: "building",
    title: "Instalaciones",
    description: "Implementamos sistemas de climatización y refrigeración con puesta en marcha en terreno y verificación de funcionamiento.",
  },
  {
    iconName: "wrench",
    title: "Reparaciones",
    description: "Diagnosticamos y resolvemos fallas en equipos HVAC/refrigeración para reducir detenciones y recuperar operación segura.",
  },
  {
    iconName: "calendar",
    title: "Mantenciones",
    description: "Ejecutamos mantenciones preventivas y correctivas para extender la vida útil de los equipos y evitar fallas repetitivas.",
  },
  {
    iconName: "zap",
    title: "Emergencias",
    description: "Respondemos contingencias críticas con atención prioritaria y reporte claro de lo ejecutado en cada intervención.",
  },
  {
    iconName: "document",
    title: "Proyectos",
    description: "Desarrollamos proyectos HVAC/refrigeración desde la definición técnica hasta la implementación y entrega operativa.",
  },
];
---

<section id="servicios" class=" bg-linear-to-b from-neutral-100 via-white to-neutral-100 py-20 lg:py-28">
  <div class="container">
    <SectionHeading
      title="Servicios"
      description="Acompañamos operaciones industriales y comerciales con servicios HVAC/refrigeración en todo Chile, desde soporte puntual hasta continuidad contractual."
    />


    <div class="flex flex-wrap justify-center gap-6">
      {services.map((service) => (
        <ServiceCard
          title={service.title}
          description={service.description}
          iconName={service.iconName}
          class="w-full md:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)]"
        />
      ))}
    </div>

    <div class="mt-10 flex justify-center">
      <Button href="#contacto" variant="accent" size="lg">
        Solicitar diagnóstico inicial
      </Button>
    </div>
  </div>
</section>
