---
import ServiceCard from "@molecules/ServiceCard.astro";
import SectionHeading from "@molecules/SectionHeading.astro";
import Button from "@atoms/Button.astro";

const services = [
  {
    iconName: "building",
    title: "Instalaciones",
    description: "Montaje de sistemas de climatización y refrigeración industrial/comercial con puesta en marcha técnica y validación operativa.",
  },
  {
    iconName: "wrench",
    title: "Reparaciones",
    description: "Diagnóstico y reparación de fallas en equipos HVAC y refrigeración, priorizando continuidad operacional y seguridad.",
  },
  {
    iconName: "calendar",
    title: "Mantenciones",
    description: "Planes preventivos y correctivos para extender vida útil de equipos, reducir detenciones y optimizar desempeño.",
  },
  {
    iconName: "zap",
    title: "Emergencias",
    description: "Respuesta técnica para contingencias críticas con protocolos de atención prioritaria y trazabilidad de intervención.",
  },
  {
    iconName: "document",
    title: "Proyectos",
    description: "Desarrollo integral de proyectos HVAC y refrigeración, desde ingeniería de detalle hasta implementación en terreno.",
  },
];
---

<section id="servicios" class=" bg-linear-to-b from-neutral-100 via-white to-neutral-100 py-20 lg:py-28">
  <div class="container">
    <SectionHeading
      title="Servicios técnicos para continuidad operativa"
      description="Instalamos, reparamos, mantenemos y ejecutamos proyectos HVAC/refrigeración con cobertura operativa de norte a sur de Chile."
    />


    <div class="flex flex-wrap justify-center gap-6">
      {services.map((service) => (
        <ServiceCard
          title={service.title}
          description={service.description}
          iconName={service.iconName}
          class="w-full md:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)]"
        />
      ))}
    </div>

    <div class="mt-10 flex justify-center">
      <Button href="#contacto" variant="accent" size="lg">
        Solicitar evaluación técnica
      </Button>
    </div>
  </div>
</section>
