---
import ServiceCard from "@molecules/ServiceCard.astro";

const services = [
  {
    iconName: "building",
    title: "HVAC Industrial",
    description: "Diseño y montaje de climatización centralizada para plantas productivas, centros logísticos y grandes superficies.",
  },
  {
    iconName: "snowflake",
    title: "Refrigeración Comercial",
    description: "Implementación de cámaras frigoríficas y sistemas de cadena de frío para retail, alimentos y logística.",
  },
  {
    iconName: "document",
    title: "Proyecto Llave en Mano",
    description: "Gestión integral desde la ingeniería de detalle hasta la puesta en marcha y documentación técnica final.",
  },
  {
    iconName: "wrench",
    title: "Mantenimiento Contractual",
    description: "Planes preventivos con métricas de desempeño, reportes periódicos y atención correctiva prioritaria.",
  },
  {
    iconName: "zap",
    title: "Atención de Emergencias",
    description: "Intervención técnica para eventos críticos con protocolos de continuidad operativa y trazabilidad.",
  },
  {
    iconName: "award",
    title: "Auditoría Técnica",
    description: "Diagnóstico de eficiencia energética, estado de activos y recomendaciones para optimizar costos operativos.",
  },
];
---

<section id="servicios" class="border-b border-secondary-200/80 bg-neutral-100 py-20 lg:py-28">
  <div class="container">
    <div class="mx-auto mb-12 max-w-3xl text-center lg:mb-16">
      <h2 class="mt-4 text-3xl font-black leading-tight text-secondary-500 sm:text-4xl lg:text-5xl">Servicios HVAC para industria y comercio</h2>
      <p class="mt-5 text-base text-secondary-300 sm:text-lg">
        Ejecutamos proyectos con foco en continuidad operacional, eficiencia energética y cumplimiento técnico.
      </p>
    </div>


    <div class="grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
      {services.map((service) => (
        <ServiceCard title={service.title} description={service.description} iconName={service.iconName} />
      ))}
    </div>
  </div>
</section>
