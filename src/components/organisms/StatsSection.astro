---
import StatItem from "@atoms/StatItem.astro";

const stats = [
  {
    value: "15+",
    label: "Años de experiencia",
    iconName: "clock",
  },
  {
    value: "4.800+",
    label: "Equipos implementados",
    iconName: "thermometer",
  },
  {
    value: "2.500+",
    label: "Clientes atendidos",
    iconName: "users",
  },
  {
    value: "98%",
    label: "Satisfacción reportada",
    iconName: "award",
  },
];
---

<section class="bg-primary-500 py-20 lg:py-28">
  <div class="container">
    <div class="mx-auto mb-12 max-w-3xl text-center lg:mb-16">
      <p class="text-xs font-semibold uppercase tracking-[0.14em] text-primary-100">Impacto operativo</p>
      <h2 class="mt-4 text-3xl font-black leading-tight text-white sm:text-4xl lg:text-5xl">Resultados medibles en terreno</h2>
      <p class="mt-5 text-base text-primary-100 sm:text-lg">
        Nuestra operación combina ejecución técnica, trazabilidad y cumplimiento de objetivos de negocio.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {stats.map((stat) => (
        <StatItem value={stat.value} label={stat.label} iconName={stat.iconName} />
      ))}
    </div>
  </div>
</section>
