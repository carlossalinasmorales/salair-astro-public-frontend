---
import StatCard from "@molecules/StatCard.astro";
import SectionHeading from "@molecules/SectionHeading.astro";

const stats = [
  {
    value: "15+",
    label: "Años en terreno",
    iconName: "clock",
  },
  {
    value: "4.800+",
    label: "Equipos intervenidos",
    iconName: "thermometer",
  },
  {
    value: "2.500+",
    label: "Atenciones realizadas",
    iconName: "users",
  },
  {
    value: "98%",
    label: "Satisfacción reportada",
    iconName: "award",
  },
];
---

<section class="bg-primary-500 py-20 lg:py-28">
  <div class="container">
    <SectionHeading
      title="Resultados"
      description="Indicadores de trabajo en terreno que reflejan continuidad, cumplimiento y capacidad de respuesta."
      tone="dark"
    />

    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {stats.map((stat) => (
        <StatCard value={stat.value} label={stat.label} iconName={stat.iconName} />
      ))}
    </div>
  </div>
</section>
