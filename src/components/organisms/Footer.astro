---
const currentYear = new Date().getFullYear();

const services = [
  "HVAC Industrial",
  "Refrigeración Comercial",
  "Proyecto llave en mano",
  "Mantenimiento contractual",
  "Auditoría técnica",
];

const quickLinks = [
  { href: "#servicios", label: "Servicios" },
  { href: "#nosotros", label: "Nosotros" },
  { href: "#testimonios", label: "Clientes" },
  { href: "#contacto", label: "Contacto" },
];
---

<footer class="border-t border-secondary-500 bg-secondary-700 py-14">
  <div class="container">
    <div class="grid grid-cols-1 gap-10 md:grid-cols-4">
      <div class="md:col-span-2">
        <div class="mb-5 flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-secondary-500 text-white ring-1 ring-secondary-300/25">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5">
              <path d="M12 2v20M2 12h20" />
              <path d="M12 2a4 4 0 0 0 0 8 4 4 0 0 0 0-8" />
              <path d="M12 22a4 4 0 0 0 0-8 4 4 0 0 0 0 8" />
              <path d="M2 12a4 4 0 0 0 8 0 4 4 0 0 0-8 0" />
              <path d="M22 12a4 4 0 0 0-8 0 4 4 0 0 0 8 0" />
            </svg>
          </div>
          <span class="text-xl font-extrabold tracking-[0.08em] text-white">
            SAL<span class="text-primary-400">AIR</span>
          </span>
        </div>

        <p class="max-w-md text-sm text-secondary-100/95">
          Ingeniería de climatización y refrigeración para empresas que requieren continuidad operativa,
          seguridad técnica y control de desempeño energético.
        </p>

        <div class="mt-5 space-y-1 text-sm text-secondary-200">
          <p>RUT: 76.XXX.XXX-X</p>
          <p>Certificaciones SEC disponibles bajo solicitud</p>
        </div>
      </div>

      <div>
        <h3 class="mb-4 text-sm font-bold uppercase tracking-[0.13em] text-white">Navegación</h3>
        <ul class="space-y-2">
          {quickLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-secondary-100 transition-colors hover:text-primary-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-400 focus-visible:ring-offset-2 focus-visible:ring-offset-secondary-700"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="mb-4 text-sm font-bold uppercase tracking-[0.13em] text-white">Servicios</h3>
        <ul class="space-y-2">
          {services.map((service) => (
            <li>
              <a
                href="#servicios"
                class="text-sm text-secondary-100 transition-colors hover:text-primary-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-400 focus-visible:ring-offset-2 focus-visible:ring-offset-secondary-700"
              >
                {service}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-10 flex flex-col items-start justify-between gap-3 border-t border-secondary-500 pt-6 sm:flex-row sm:items-center">
      <p class="text-sm text-secondary-200">© {currentYear} Salair Chile. Todos los derechos reservados.</p>
      <p class="text-sm text-secondary-200">Climatización y refrigeración profesional para el sector productivo.</p>
    </div>
  </div>
</footer>
