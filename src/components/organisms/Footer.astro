---
import Logo from "@atoms/Logo.astro";
import { mainNavLinks } from "@/lib/navigation/nav-links";
import { footerServices } from "@/lib/navigation/footer-data";

const currentYear = new Date().getFullYear();
const navLinks = mainNavLinks ?? [];
const services = footerServices ?? [];
---

<footer class="bg-neutral-100 py-14">
  <div class="container">
    <div class="grid grid-cols-1 gap-10 border-t border-secondary-200/30 pt-10 md:grid-cols-4">
      <div class="md:col-span-2">
        <div class="mb-5 flex items-center gap-3">
          <Logo variant="default" size="md" alt="SALAIR" />
        </div>

        <p class="max-w-md text-sm text-secondary-300">
          Climatización y refrigeración industrial para empresas que requieren continuidad operativa.
        </p>


      </div>

      <div>
        <h3 class="mb-4 text-sm font-bold uppercase tracking-widest text-secondary-500">Navegación</h3>
        <ul class="space-y-2">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-secondary-300 transition-colors hover:text-primary-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-400 focus-visible:ring-offset-2 focus-visible:ring-offset-neutral-100"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="mb-4 text-sm font-bold uppercase tracking-widest text-secondary-500">Servicios</h3>
        <ul class="space-y-2">
          {services.map((service) => (
            <li>
              <span class="text-sm text-secondary-300">
                {service}
              </span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-10 flex flex-col items-start justify-between gap-3 pt-6 sm:flex-row sm:items-center">
      <p class="text-sm text-secondary-300">SALAIR ® {currentYear}</p>

    </div>
  </div>
</footer>
