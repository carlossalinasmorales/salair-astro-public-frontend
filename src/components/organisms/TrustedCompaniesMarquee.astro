---
import { Image } from "astro:assets";

import burgerKingLogo from "@assets/images/empresas/burgerking.jpg";
import chinaWokLogo from "@assets/images/empresas/chinawok.jpg";
import degasaLogo from "@assets/images/empresas/degasa.jpg";
import jrLogo from "@assets/images/empresas/jr.jpg";
import kfcLogo from "@assets/images/empresas/kfc.jpg";
import tarragonaLogo from "@assets/images/empresas/tarragona.jpg";
import telepizzaLogo from "@assets/images/empresas/telepizza.jpg";
import unoSaludLogo from "@assets/images/empresas/unosalud.jpg";
import wendysLogo from "@assets/images/empresas/wendys.jpg";

const companies = [
  { name: "Burger King", logo: burgerKingLogo },
  { name: "China Wok", logo: chinaWokLogo },
  { name: "Degasa", logo: degasaLogo },
  { name: "JR", logo: jrLogo },
  { name: "KFC", logo: kfcLogo },
  { name: "Tarragona", logo: tarragonaLogo },
  { name: "Telepizza", logo: telepizzaLogo },
  { name: "Uno Salud", logo: unoSaludLogo },
  { name: "Wendy's", logo: wendysLogo },
];

interface Props {
  embedded?: boolean;
  class?: string;
}

const { embedded = false, class: className = "" } = Astro.props;

const embeddedLogoClasses = "h-12 w-auto object-contain lg:h-16";
const defaultLogoClasses = "h-12 w-auto object-contain md:h-18";
---

{
  embedded ? (
    <div class:list={["w-full", className]} aria-labelledby="empresas-atendidas">
      <div class="marquee rounded-xl px-3 py-3 shadow-lg" aria-label="Logos de empresas atendidas">
        <ul class="marquee__track" role="list">
          {
            companies.map((company) => (
              <li class="marquee__item">
                <Image
                  src={company.logo}
                  alt={`Logo de ${company.name}`}
                  class={embeddedLogoClasses}
                  loading="lazy"
                  decoding="async"
                />
              </li>
            ))
          }
        </ul>

        <ul class="marquee__track" aria-hidden="true" role="presentation">
          {
            companies.map((company) => (
              <li class="marquee__item">
                <Image
                  src={company.logo}
                  alt=""
                  class={embeddedLogoClasses}
                  loading="lazy"
                  decoding="async"
                />
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  ) : (
    <section aria-labelledby="empresas-atendidas" class:list={[className]} >
      <div class="container min-h-20 content-center">


        <div class="marquee" aria-label="Logos de empresas atendidas">
          <ul class="marquee__track" role="list">
            {
              companies.map((company) => (
                <li class="marquee__item">
                  <Image
                    src={company.logo}
                    alt={`Logo de ${company.name}`}
                    class={defaultLogoClasses}
                    loading="lazy"
                    decoding="async"
                  />
                </li>
              ))
            }
          </ul>

          <ul class="marquee__track" aria-hidden="true" role="presentation">
            {
              companies.map((company) => (
                <li class="marquee__item">
                  <Image
                    src={company.logo}
                    alt=""
                    class={defaultLogoClasses}
                    loading="lazy"
                    decoding="async"
                  />
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </section>
  )
}

<style>
  .marquee {
    display: flex;
    width: 100%;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }

  .marquee__track {
    display: flex;
    flex-shrink: 0;
    width: max-content;
    align-items: center;
    gap: clamp(2rem, 5vw, 4rem);
    padding-inline-end: clamp(2rem, 5vw, 4rem);
    animation: logos-marquee 30s linear infinite;
  }

  .marquee__item {
    display: grid;
    place-items: center;
    min-width: 8rem;
    opacity: 0.78;
    filter: grayscale(1) contrast(1.04);
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee {
      overflow-x: auto;
      mask-image: none;
      -webkit-mask-image: none;
    }

    .marquee__track {
      animation: none;
    }
  }

  @keyframes logos-marquee {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-100%);
    }
  }
</style>
