---
interface Props {
  label: string;
  href?: string;
  class?: string;
}

const { label, href = "#", class: className = "" } = Astro.props;
---

<a
  href={href}
  class={`rounded-lg border border-transparent px-4 py-2 text-sm font-semibold text-secondary-500 transition-all duration-200 hover:border-secondary-300 hover:bg-neutral-100/85 hover:text-secondary-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2 focus-visible:ring-offset-neutral-100 active:bg-neutral-200 ${className}`}
>
  {label}
</a>
