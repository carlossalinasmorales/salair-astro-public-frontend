---
interface Props {
  variant?: "primary" | "secondary" | "outline-white" | "accent";
  href?: string;
  type?: "button" | "submit";
  disabled?: boolean;
  class?: string;
}

const {
  variant = "primary",
  href,
  type = "button",
  disabled = false,
  class: className = "",
} = Astro.props;

const baseClasses = "inline-flex items-center justify-center gap-2 rounded-sm text-sm  font-bold transition-all duration-200 uppercase";

const variantClasses = {
  "primary": "border-1 border-primary-500 bg-primary-500 text-white hover:border-primary-300 hover:bg-primary-300",
  "secondary": "border-1 border-secondary-500 bg-secondary-500 text-white hover:border-secondary-300 hover:bg-secondary-300",
  "outline-white": "border-1 border-white bg-transparent text-white hover:border-white hover:bg-white hover:text-secondary-500",
  "accent": "bg-accent-500 text-neutral-100  hover:bg-accent-300 hover:text-white",
};

const responsiveSizeClasses = "px-6 py-3 lg:px-8 lg:py-4";

const classes = `${baseClasses} ${variantClasses[variant]} ${responsiveSizeClasses} ${className}`;
---

{href ? (
  <a href={href} class={classes}>
    <slot />
  </a>
) : (
  <button type={type} disabled={disabled} class={classes}>
    <slot />
  </button>
)}
