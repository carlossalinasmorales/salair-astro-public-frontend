---
interface Props {
  variant?: "primary" | "secondary" | "outline-light" | "outline-dark";
  href?: string;
  type?: "button" | "submit";
  disabled?: boolean;
  class?: string;
}

const {
  variant = "primary",
  href,
  type = "button",
  disabled = false,
  class: className = "",
} = Astro.props;

const baseClasses = "inline-flex items-center justify-center gap-2 rounded-sm text-sm font-bold transition-colors duration-200 uppercase cursor-pointer";

const variantClasses = {
  "primary": "border-1 border-primary-600 bg-primary-600 text-neutral-100 hover:border-primary-300 hover:bg-primary-300",
  "secondary": "border-1 border-secondary-500 bg-secondary-500 text-neutral-100 hover:border-secondary-300 hover:bg-secondary-300",
  "outline-light": "border-1 border-neutral-100 bg-transparent text-neutral-100 hover:border-neutral-100 hover:bg-neutral-100 hover:text-secondary-500",
  "outline-dark": "border-1 border-secondary-500 bg-transparent text-secondary-500 hover:border-secondary-500 hover:bg-secondary-500 hover:text-neutral-100",
};

const responsiveSizeClasses = "px-6 py-3 lg:px-7 lg:py-3.5";

const classes = `${baseClasses} ${variantClasses[variant]} ${responsiveSizeClasses} ${className}`;
---

{href ? (
  <a href={href} class={classes}>
    <slot />
  </a>
) : (
  <button type={type} disabled={disabled} class={classes}>
    <slot />
  </button>
)}
