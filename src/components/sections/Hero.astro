---
import { Image } from 'astro:assets';
import Button from '@atoms/Button.astro';
import heroImage from '@assets/images/hero-image.webp';
---

<section class="relative content-end overflow-hidden py-20 pt-24 lg:py-28 lg:pt-32 min-h-[90dvh]">
  <Image
    src={heroImage}
    alt=""
    loading="lazy"
    sizes="100vw"
    class="absolute inset-0 h-full w-full object-cover object-[78%_center] md:object-center"
    />

  <div
    class="absolute inset-0 bg-linear-to-b from-secondary-900/80 from-50% to-neutral-100 to-100%"
  >
  </div>

  <div class="container relative z-10 text-neutral-100 mb-14">
    <div class="mx-auto flex max-w-sm md:max-w-6xl flex-col items-center text-center">
      <h1 class="hero-heading">Soluciones de climatización y refrigeración industrial.</h1>

      <p class="mt-6 max-w-3xl text-sm md:text-xl sm:text-lg/6">
        Tu negocio necesita seguir funcionando.
      </p>

      <div class="mt-10 flex flex-row gap-3">
        <Button href="#contacto" variant="primary">Contacto</Button>
        <Button href="#servicios" variant="outline-light"> Servicios </Button>
      </div>
    </div>
  </div>
</section>
