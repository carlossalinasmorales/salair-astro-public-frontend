---
import BenefitItem from '@molecules/BenefitItem.astro';
import { benefits } from '@/lib/content/benefits';
---

<section id="beneficios" class="section-shell">
  <div class="container">
    <div class="section-heading">
      <h2 class="section-title">Te brindamos el respaldo y continuidad operativa que necesitas.</h2>
    </div>

    <div class="mx-auto grid max-w-6xl grid-cols-1 gap-0 lg:grid-cols-2">
      {
        benefits.map((benefit) => (
          <BenefitItem
            number={benefit.number}
            title={benefit.title}
            description={benefit.description}
          />
        ))
      }
    </div>
  </div>
</section>
