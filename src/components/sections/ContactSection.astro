---
import Button from '@atoms/Button.astro';
import FormField from '@molecules/FormField.astro';
import FormTextareaField from '@molecules/FormTextareaField.astro';
---

<section id="contacto" class="section-shell">
  <div class="container justify-items-center">
    <div class="section-heading">
      <h2 class="section-title">Cuéntanos tu desafío y te damos una solución técnica clara.</h2>
    </div>
    <div class="max-w-3xl gap-10">
      <div class="surface-panel p-8">
        <form id="contact-form" class="space-y-5" data-state="idle">
          <div
            id="form-feedback"
            class="hidden rounded-sm border bg-primary-500 text-neutral-100 p-4 text-sm"
            role="status"
            aria-live="polite"
          >
          </div>

          <FormField
            id="company"
            name="company"
            label="Empresa"
            autocomplete="organization"
            required
            minLength={2}
            maxLength={120}
            placeholder="Ej: Planta Andina SpA"
          />

          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <FormField
              id="firstName"
              name="firstName"
              label="Nombre"
              autocomplete="given-name"
              required
              minLength={2}
              maxLength={60}
              pattern="^[A-Za-zÁÉÍÓÚáéíóúÑñÜü' -]+$"
              placeholder="Nombre"
            />
            <FormField
              id="lastName"
              name="lastName"
              label="Apellido"
              autocomplete="family-name"
              required
              minLength={2}
              maxLength={60}
              pattern="^[A-Za-zÁÉÍÓÚáéíóúÑñÜü' -]+$"
              placeholder="Apellido"
            />
          </div>

          <FormField
            id="role"
            name="role"
            label="Cargo"
            maxLength={80}
            placeholder="Ej: Jefe de Operaciones"
          />

          <FormField
            id="email"
            name="email"
            type="email"
            label="Correo corporativo"
            autocomplete="email"
            required
            inputMode="email"
            maxLength={254}
            placeholder="su@empresa.cl"
          />

          <FormTextareaField
            id="message"
            name="message"
            label="Mensaje"
            rows={4}
            required
            minLength={20}
            maxLength={2000}
            placeholder="Contexto operativo, metraje estimado, criticidad y plazo objetivo"
            description="Entre 20 y 2000 caracteres. Entre más contexto entregue, mejor propuesta técnica recibirá."
          />

          <div
            class="absolute left-[-9999px] top-auto h-px w-px overflow-hidden"
            aria-hidden="true"
          >
            <label for="website">No completar este campo</label>
            <input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
          </div>

          <Button type="submit" variant="primary" class="w-full">
            <span id="btn-text" aria-live="polite">Enviar</span>
          </Button>

          <p class="text-xs text-secondary-400">
            Al enviar este formulario acepta que usemos estos datos para contactarlo y preparar una
            propuesta.
          </p>

          <p class="text-xs text-secondary-400">
            Nota: el envío actual es una simulación local. No existe conexión real con backend
            todavía.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const setupDeferredContactFormInit = () => {
    const section = document.getElementById('contacto');
    const form = document.getElementById('contact-form');

    if (!(section instanceof HTMLElement) || !(form instanceof HTMLFormElement)) {
      return;
    }

    if (section.dataset.deferredInit === 'true') {
      return;
    }

    section.dataset.deferredInit = 'true';

    let hasLoadedModule = false;
    let observer: IntersectionObserver | null = null;

    const cleanup = () => {
      observer?.disconnect();
      document.removeEventListener('focusin', onFocusIn, true);
      section.removeEventListener('pointerenter', triggerInit);
      section.removeEventListener('touchstart', triggerInit);
    };

    const loadAndInit = async () => {
      if (hasLoadedModule) {
        return;
      }

      hasLoadedModule = true;

      try {
        const { initContactForm } = await import('@/scripts/contact-form');
        initContactForm();
        cleanup();
      } catch {
        hasLoadedModule = false;
      }
    };

    const triggerInit = () => {
      void loadAndInit();
    };

    const onFocusIn = (event: FocusEvent) => {
      const target = event.target;
      if (target instanceof Node && form.contains(target)) {
        triggerInit();
      }
    };

    document.addEventListener('focusin', onFocusIn, true);
    section.addEventListener('pointerenter', triggerInit, { once: true, passive: true });
    section.addEventListener('touchstart', triggerInit, { once: true, passive: true });

    if ('IntersectionObserver' in window) {
      observer = new IntersectionObserver(
        (entries) => {
          const [entry] = entries;
          if (entry?.isIntersecting) {
            triggerInit();
          }
        },
        { rootMargin: '220px 0px' },
      );

      observer.observe(section);
      return;
    }

    triggerInit();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupDeferredContactFormInit, { once: true });
  } else {
    setupDeferredContactFormInit();
  }

  document.addEventListener('astro:page-load', setupDeferredContactFormInit);
</script>
