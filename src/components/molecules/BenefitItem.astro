---
interface Props {
  number: string;
  title: string;
  description: string;
  class?: string;
}

const { number, title, description, class: className = "" } = Astro.props;
---

<div class={`flex gap-5 rounded-2xl border border-secondary-500 bg-secondary-600 p-6 shadow-[0_16px_34px_-30px_rgba(2,6,15,0.86)] transition-all duration-200 hover:border-primary-400 hover:shadow-[0_22px_40px_-34px_rgba(2,6,15,0.95)] ${className}`}>
  <span class="select-none text-4xl font-black leading-none text-primary-300">
    {number}
  </span>
  <div>
    <h3 class="mb-2 text-lg font-bold text-white">{title}</h3>
    <p class="text-sm text-secondary-100/90">{description}</p>
  </div>
</div>
