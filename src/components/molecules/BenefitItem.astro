---
interface Props {
  number: string;
  title: string;
  description: string;
  class?: string;
}

const { number, title, description, class: className = "" } = Astro.props;
---

<div class={`flex gap-5 rounded-2xl border border-secondary-200/80 bg-white p-6 shadow-[0_14px_28px_-22px_rgba(9,26,56,0.65)] transition-all duration-200 hover:border-primary-300 hover:shadow-[0_16px_30px_-25px_rgba(9,26,56,0.9)] ${className}`}>
  <span class="select-none text-4xl font-black leading-none text-primary-500">
    {number}
  </span>
  <div>
    <h3 class="mb-2 text-lg font-bold text-secondary-500">{title}</h3>
    <p class="text-sm text-secondary-300">{description}</p>
  </div>
</div>
