---
import Icon from "@atoms/Icon.astro";
import SurfaceCard from "@atoms/SurfaceCard.astro";

interface Props {
  value: string;
  label: string;
  iconName?: string;
  class?: string;
}

const { value, label, iconName, class: className = "" } = Astro.props;
---

<SurfaceCard
  as="article"
  tone="light"
  class={`h-full p-7 text-center border-primary-200/70 shadow-[0_18px_34px_-26px_rgba(9,26,56,0.55)] ${className}`}
>
  {iconName && (
    <div class="mx-auto mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-secondary-500 text-white shadow-[0_12px_24px_-16px_rgba(9,26,56,0.9)]">
      <Icon name={iconName} class="h-5 w-5" />
    </div>
  )}
  <div class="mb-2 text-3xl font-black text-secondary-500 sm:text-4xl">
    {value}
  </div>
  <div class="text-sm font-medium text-secondary-300">
    {label}
  </div>
</SurfaceCard>
