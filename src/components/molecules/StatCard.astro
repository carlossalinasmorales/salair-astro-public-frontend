---
import SurfaceCard from "@atoms/SurfaceCard.astro";

interface Props {
  value: string;
  label: string;
  class?: string;
}

const { value, label, class: className = "" } = Astro.props;
---

<SurfaceCard
  as="article"
  tone="light"
  class={`group relative h-full overflow-hidden rounded-2xl border-white/80 bg-white/95 px-6 py-8 text-center shadow-[0_28px_54px_-32px_rgba(4,12,26,0.75)] backdrop-blur-[2px] transition-shadow duration-300 hover:shadow-[0_34px_62px_-30px_rgba(4,12,26,0.85)] ${className}`}
>
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 bg-linear-to-b from-white via-white to-primary-100/35"></div>
  <div aria-hidden="true" class="pointer-events-none absolute -right-10 -top-10 h-28 w-28 rounded-full bg-primary-200/55 blur-2xl"></div>
  <div aria-hidden="true" class="pointer-events-none absolute -left-8 bottom-0 h-24 w-24 rounded-full bg-secondary-200/40 blur-2xl"></div>

  <div class="relative">
    <div
      class="js-stat-value mb-2 text-5xl leading-none font-black tracking-tight text-primary-500 sm:text-6xl lg:text-7xl"
      data-stat-value={value}
    >
      {value}
    </div>
    <div aria-hidden="true" class="mx-auto mb-3 h-px w-16 bg-primary-300/80"></div>
    <div class="mx-auto max-w-[24ch] text-sm font-semibold text-secondary-400 sm:text-base">
      {label}
    </div>
  </div>
</SurfaceCard>
