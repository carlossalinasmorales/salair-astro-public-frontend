interface Props {
  title: string;
  description?: string;
  items?: string[];
  class?: string;
}

const { title, description, items = [], class: className = "" } = Astro.props;
---

<article class={`rounded-sm border border-primary-200/60 bg-primary-400/30 p-5 shadow-lg backdrop-blur-sm ${className}`}>
  <h3 class="text-base font-bold text-white">{title}</h3>

  {description && <p class="mt-2 text-sm text-primary-100/95">{description}</p>}

  {
    items.length > 0 && (
      <ul class="mt-3 space-y-2 text-sm text-primary-100/95">
        {items.map((item) => (
          <li>• {item}</li>
        ))}
      </ul>
    )
  }
</article>
