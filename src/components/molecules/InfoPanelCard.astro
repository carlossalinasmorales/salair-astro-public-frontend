---
import SurfaceCard from "@atoms/SurfaceCard.astro";

interface Props {
  title: string;
  description?: string;
  items?: string[];
  class?: string;
}

const { title, description, items = [], class: className = "" } = Astro.props;
---

<SurfaceCard as="article" tone="dark" class={`p-5 backdrop-blur-[1px] ${className}`}>
  <h3 class="text-base font-bold text-white">{title}</h3>

  {description && <p class="mt-2 text-sm text-primary-100/95">{description}</p>}

  {
    items.length > 0 && (
      <ul class="mt-3 space-y-2 text-sm text-primary-100/95">
        {items.map((item) => (
          <li>• {item}</li>
        ))}
      </ul>
    )
  }
</SurfaceCard>
