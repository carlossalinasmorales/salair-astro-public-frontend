---
interface Props {
  id: string;
  name: string;
  label: string;
  type?: "text" | "email" | "tel";
  autocomplete?: string;
  placeholder?: string;
  required?: boolean;
  class?: string;
}

const {
  id,
  name,
  label,
  type = "text",
  autocomplete,
  placeholder,
  required = false,
  class: className = "",
} = Astro.props;
---

<div class={className}>
  <label for={id} class="mb-2 block text-sm font-semibold text-secondary-500">
    {label}
    {required && " *"}
  </label>
  <input
    type={type}
    id={id}
    name={name}
    autocomplete={autocomplete}
    required={required}
    placeholder={placeholder}
    class="w-full rounded-xl border border-secondary-200 bg-neutral-100 px-4 py-3 text-sm text-secondary-500 placeholder-secondary-300 transition-colors hover:border-secondary-300 focus-visible:border-primary-400"
  />
</div>
