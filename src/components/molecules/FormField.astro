---
interface Props {
  id: string;
  name: string;
  label: string;
  type?: "text" | "email" | "tel";
  autocomplete?: string;
  placeholder?: string;
  required?: boolean;
  minLength?: number;
  maxLength?: number;
  pattern?: string;
  inputMode?: "text" | "email" | "tel" | "search" | "url" | "none" | "numeric" | "decimal";
  description?: string;
  describedBy?: string;
  class?: string;
}

const {
  id,
  name,
  label,
  type = "text",
  autocomplete,
  placeholder,
  required = false,
  minLength,
  maxLength,
  pattern,
  inputMode,
  description,
  describedBy,
  class: className = "",
} = Astro.props;

const hintId = description ? `${id}-hint` : undefined;
const errorId = `${id}-error`;
const describedByIds = [describedBy, hintId, errorId].filter(Boolean).join(" ");
---

<div class={className} data-field-wrapper={id}>
  <label for={id} class="mb-2 block text-sm font-semibold text-secondary-500">
    {label}
    {required && <span aria-hidden="true"> *</span>}
  </label>
  <input
    type={type}
    id={id}
    name={name}
    autocomplete={autocomplete}
    required={required}
    minLength={minLength}
    maxLength={maxLength}
    pattern={pattern}
    inputmode={inputMode}
    aria-invalid="false"
    aria-describedby={describedByIds}
    placeholder={placeholder}
    class="form-control border-secondary-200/30"
  />

  {description && (
    <p id={hintId} class="mt-2 text-xs text-secondary-400">
      {description}
    </p>
  )}

  <p id={errorId} class="mt-2 hidden text-sm font-semibold text-primary-600" data-field-error aria-live="polite"></p>
</div>
