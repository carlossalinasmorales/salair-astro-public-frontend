---
import Icon from "@atoms/Icon.astro";

interface Props {
  title: string;
  description: string;
  iconName: string;
  class?: string;
}

const { title, description, iconName, class: className = "" } = Astro.props;
---

<article class={`service-card-reference group relative h-full overflow-hidden bg-neutral-100 px-8 py-10 transition-colors duration-300 hover:bg-white ${className}`}>
  <div aria-hidden="true" class="absolute inset-0 bg-[radial-gradient(circle_at_35%_35%,rgba(201,227,248,0.18),transparent_58%)] opacity-80"></div>

  <div class="relative z-10 flex h-full flex-col">
    <Icon name={iconName} class="mb-10 h-10 w-10 text-primary-400" />

    <h3 class="text-[2.05rem] leading-tight font-semibold tracking-tight text-secondary-500">{title}</h3>

    <p class="mt-4 max-w-[34ch] text-[1.05rem] leading-relaxed text-secondary-300">{description}</p>
  </div>
</article>
