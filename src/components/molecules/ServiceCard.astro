---
import Icon from "@atoms/Icon.astro";

interface Props {
  title: string;
  description: string;
  iconName: string;
  class?: string;
}

const { title, description, iconName, class: className = "" } = Astro.props;
---

<article class={`group h-full rounded-2xl border border-secondary-200/80 bg-white p-7 shadow-[0_14px_28px_-22px_rgba(9,26,56,0.65)] transition-all duration-200 hover:-translate-y-1 hover:border-primary-300 hover:shadow-[0_20px_40px_-30px_rgba(9,26,56,0.85)] ${className}`}>
  <div class="mb-5 flex h-11 w-11 items-center justify-center rounded-xl bg-secondary-500 text-white transition-colors group-hover:bg-primary-500">
    <Icon name={iconName} class="h-5 w-5" />
  </div>
  <h3 class="mb-3 text-xl font-bold text-secondary-500">{title}</h3>
  <p class="text-sm text-secondary-300">{description}</p>
</article>
