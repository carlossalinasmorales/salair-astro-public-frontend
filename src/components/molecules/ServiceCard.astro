---
import Icon from "@atoms/Icon.astro";
import SurfaceCard from "@atoms/SurfaceCard.astro";

interface Props {
  title: string;
  description: string;
  iconName: string;
  class?: string;
}

const { title, description, iconName, class: className = "" } = Astro.props;
---

<SurfaceCard as="article" tone="light" interactive class={`group relative h-full overflow-hidden p-7 ${className}`}>
  <div aria-hidden="true" class="absolute inset-x-0 top-0 h-1 bg-linear-to-r from-primary-500 via-secondary-500 to-primary-300 opacity-80"></div>
  <div aria-hidden="true" class="absolute -right-10 -top-10 h-32 w-32 rounded-full bg-primary-200/35 blur-2xl"></div>

  <div class="relative z-10 flex h-full flex-col">
    <div class="mb-4 flex items-center gap-3">
      <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-secondary-500 text-white shadow-[0_12px_24px_-16px_rgba(9,26,56,0.9)]">
        <Icon name={iconName} class="h-5 w-5" />
      </div>
      <h3 class="text-xl font-bold text-secondary-500">{title}</h3>
    </div>

    <p class="text-sm leading-relaxed text-secondary-300">{description}</p>
  </div>
</SurfaceCard>
