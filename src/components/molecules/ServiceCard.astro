---
import ServiceOrbitIcon from "@/components/illustrations/ServiceOrbitIcon.tsx";

interface Props {
  title: string;
  description: string;
  iconVariant?: "cooling" | "heating" | "compressor" | "thermostat" | "ventilation" | "heatpump";
  class?: string;
}

const { title, description, iconVariant = "cooling", class: className = "" } = Astro.props;
---

<article class={`service-card-reference surface-card px-8 py-10 ${className}`}>
  <div aria-hidden="true" class="absolute inset-0"></div>

  <div class="relative z-10 flex h-full flex-col">
    <ServiceOrbitIcon variant={iconVariant} className="mb-8" />

    <h3 class="text-xl leading-tight font-semibold tracking-tight text-secondary-500 md:text-2xl">{title}</h3>

    <p class="mt-4 max-w-md text-base leading-relaxed text-secondary-300">{description}</p>
  </div>
</article>
