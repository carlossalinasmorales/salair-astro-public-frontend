---
interface Props {
  quote: string;
  name: string;
  role: string;
  company: string;
  location: string;
  avatar: string;
  class?: string;
}

const { quote, name, role, company, location, avatar, class: className = "" } = Astro.props;
---

<article class={`h-full rounded-2xl border border-secondary-200 bg-white p-7 ${className}`}>
  <blockquote class="mb-6 text-sm text-secondary-300 sm:text-base">
    "{quote}"
  </blockquote>

  <div class="flex items-center gap-4 border-t border-secondary-200 pt-4">
    <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-secondary-500 text-sm font-bold text-white">
      {avatar}
    </div>
    <div>
      <div class="text-sm font-bold text-secondary-500">{name}</div>
      <div class="text-xs text-secondary-300">{role}</div>
      <div class="text-xs font-semibold text-primary-600">{company}</div>
      <div class="text-xs text-secondary-300">{location}</div>
    </div>
  </div>
</article>
