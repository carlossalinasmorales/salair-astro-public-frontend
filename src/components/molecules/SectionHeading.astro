---
type HeadingAlign = "left" | "center";
type HeadingTone = "light" | "dark";
type HeadingTag = "h1" | "h2" | "h3";

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  align?: HeadingAlign;
  tone?: HeadingTone;
  as?: HeadingTag;
  compact?: boolean;
  class?: string;
}

const {
  title,
  description,
  eyebrow,
  align = "center",
  tone = "light",
  as = "h2",
  compact = false,
  class: className = "",
} = Astro.props;

const HeadingTag = as;
const alignClasses = align === "center" ? "mx-auto text-center" : "text-left";

const eyebrowClasses =
  tone === "dark"
    ? "text-xs font-semibold uppercase tracking-[0.14em] text-neutral-100"
    : "text-xs font-semibold uppercase tracking-[0.14em] text-secondary-100";

const titleClasses =
  compact
    ? tone === "dark"
      ? "mt-1 text-2xl font-extrabold leading-tight text-neutral-100 sm:text-3xl uppercase"
      : "mt-1 text-2xl font-extrabold leading-tight text-secondary-500 sm:text-3xl uppercase"
    : tone === "dark"
      ? "mt-4 text-3xl font-extrabold leading-tight text-neutral-100 sm:text-4xl lg:text-5xl uppercase"
      : "mt-4 text-3xl font-extrabold leading-tight text-secondary-500 sm:text-4xl lg:text-5xl uppercase";

const descriptionClasses =
  compact
    ? tone === "dark"
      ? "mt-2 text-sm text-primary-100 sm:text-base"
      : "mt-2 text-sm text-secondary-500 sm:text-base"
    : tone === "dark"
      ? "mt-5 text-base text-primary-100 sm:text-lg"
      : "mt-5 text-base text-secondary-500 sm:text-lg";
---

<div class={`${compact ? "mb-2 max-w-none" : "mb-12 max-w-3xl lg:mb-16"} ${alignClasses} ${className}`}>
  {eyebrow && <p class={eyebrowClasses}>{eyebrow}</p>}
  <HeadingTag class={titleClasses}>{title}</HeadingTag>
  {description && <p class={descriptionClasses}>{description}</p>}
</div>
