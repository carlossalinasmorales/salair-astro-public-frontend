---
type HeadingAlign = "left" | "center";
type HeadingTone = "light" | "dark";

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  align?: HeadingAlign;
  tone?: HeadingTone;
  class?: string;
}

const {
  title,
  description,
  eyebrow,
  align = "center",
  tone = "light",
  class: className = "",
} = Astro.props;

const alignClasses = align === "center" ? "mx-auto text-center" : "text-left";

const eyebrowClasses =
  tone === "dark"
    ? "text-xs font-semibold uppercase tracking-[0.14em] text-primary-100"
    : "text-xs font-semibold uppercase tracking-[0.14em] text-secondary-300";

const titleClasses =
  tone === "dark"
    ? "mt-4 text-3xl font-black leading-tight text-white sm:text-4xl lg:text-5xl"
    : "mt-4 text-3xl font-black leading-tight text-secondary-500 sm:text-4xl lg:text-5xl";

const descriptionClasses =
  tone === "dark"
    ? "mt-5 text-base text-primary-100 sm:text-lg"
    : "mt-5 text-base text-secondary-300 sm:text-lg";
---

<div class={`mb-12 max-w-3xl lg:mb-16 ${alignClasses} ${className}`}>
  {eyebrow && <p class={eyebrowClasses}>{eyebrow}</p>}
  <h2 class={titleClasses}>{title}</h2>
  {description && <p class={descriptionClasses}>{description}</p>}
</div>
