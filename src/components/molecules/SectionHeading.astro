---
type HeadingAlign = "left" | "center";
type HeadingTone = "light" | "dark";
type HeadingTag = "h1" | "h2" | "h3";

interface Props {
  title: string;
  align?: HeadingAlign;
  tone?: HeadingTone;
  as?: HeadingTag;
  compact?: boolean;
  class?: string;
}

const {
  title,
  align = "center",
  tone = "light",
  as = "h2",
  compact = false,
  class: className = "",
} = Astro.props;

const HeadingTag = as;
const alignClasses = align === "center" ? "mx-auto text-center" : "text-left";

const titleBaseClasses = "font-semibold";
const titleSpacingAndSizeClasses = compact
  ? "mt-1 text-2xl sm:text-3xl"
  : "mt-4 text-3xl sm:text-4xl lg:text-5xl";
const titleToneClasses = tone === "dark" ? "text-neutral-100" : "text-secondary-500";
const titleClasses = `${titleBaseClasses} ${titleSpacingAndSizeClasses} ${titleToneClasses}`;

---

<div class={`${compact ? "mb-2 max-w-none" : "mb-12 max-w-3xl lg:mb-16"} ${alignClasses} ${className}`}>
  <HeadingTag class={titleClasses}>{title}</HeadingTag>
</div>
