---
import Icon from "@atoms/Icon.astro";

interface Props {
  iconName: string;
  label: string;
  value: string;
  href?: string;
  class?: string;
}

const { iconName, label, value, href, class: className = "" } = Astro.props;
---

<div class={`flex items-center gap-4 rounded-2xl border border-secondary-200/80 bg-white p-4 shadow-md ${className}`}>
  <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-secondary-500 text-white">
    <Icon name={iconName} class="h-5 w-5" />
  </div>
  <div>
    <div class="text-sm text-secondary-300">{label}</div>
    {href ? (
      <a href={href} class="font-semibold text-secondary-500 transition-colors hover:text-primary-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2 focus-visible:ring-offset-neutral-100">
        {value}
      </a>
    ) : (
      <span class="font-semibold text-secondary-500">{value}</span>
    )}
  </div>
</div>
