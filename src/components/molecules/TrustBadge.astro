---
import Icon from "@atoms/Icon.astro";

interface Props {
  label: string;
  value?: string;
  icon: string;
}

const { label, value, icon } = Astro.props;
---

<div class="flex items-center gap-3">
  <span class="flex h-9 w-9 items-center justify-center rounded-xl border border-primary-300 bg-primary-100 text-primary-700">
    <Icon name={icon} class="w-4 h-4" />
  </span>
  <div class="flex flex-col">
    <span class="text-sm font-semibold text-white">{label}</span>
    {value && <span class="text-xs text-secondary-100/90">{value}</span>}
  </div>
</div>
