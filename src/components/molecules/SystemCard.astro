---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  description: string;
  image: ImageMetadata;
  alt: string;
  class?: string;
}

const { title, description, image, alt, class: className = '' } = Astro.props;
---

<article
  class={`group relative h-80 w-full overflow-hidden border border-neutral-300/20 bg-neutral-100 md:h-84 xl:h-88 ${className}`}
>
  <div aria-hidden="true" class="absolute inset-x-0 top-0 z-10 h-1 opacity-90"></div>
  <Image
    src={image}
    alt={alt}
    widths={[480, 720]}
    sizes="(max-width: 768px) 100vw, (max-width: 1280px) 50vw, 33vw"
    class="absolute inset-0 h-full w-full object-cover"
    loading="lazy"
    format="webp"
  />
  <div
    aria-hidden="true"
    class="absolute inset-0 bg-linear-to-b from-secondary-900/20 via-secondary-900/35 to-secondary-900/88"
  >
  </div>

  <div class="absolute inset-x-0 bottom-0 z-10 p-6">
    <h3
      class="min-h-14 text-xl leading-tight font-semibold tracking-tight text-neutral-100 md:text-2xl"
    >
      {title}
    </h3>
    <p class="min-h-24 text-base leading-relaxed text-neutral-100">{description}</p>
  </div>
</article>
